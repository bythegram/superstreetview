# .gitignore for Super Street View
# A plain-HTML / PHP / vanilla-JS project

# ──────────────────────────────────────────
# Operating system artefacts
# ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────────────
# Editor / IDE settings
# ──────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ──────────────────────────────────────────
# Node / npm (if a build step is added later)
# ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnp
.pnp.js
dist/
build/
.cache/

# ──────────────────────────────────────────
# Environment / secrets
# ──────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ──────────────────────────────────────────
# PHP / Composer
# ──────────────────────────────────────────
vendor/
composer.lock

# ──────────────────────────────────────────
# Logs & temporary files
# ──────────────────────────────────────────
*.log
*.tmp
*.temp
tmp/
temp/

# ──────────────────────────────────────────
# Coverage & test output
# ──────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────
*.bak
*.orig
